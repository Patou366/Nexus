modules = ["nodejs-18", "web"]

[nix]
channel = "stable-25_05"

[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node dashboard/server/index.js & cd dashboard && node_modules/.bin/vite --config vite.config.js"
waitForPort = 5000

[[ports]]
localPort = 3000
externalPort = 3002

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 5000
externalPort = 80

[userenv]

[userenv.shared]
NODE_ENV = "production"
LOG_LEVEL = "warn"
LOG_TO_FILE = "false"
PORT = "3000"
WEB_HOST = "0.0.0.0"
PORT_RETRY_ATTEMPTS = "5"
AUTO_MIGRATE = "true"
POSTGRES_SSL = "true"
POSTGRES_SSL_REJECT_UNAUTHORIZED = "false"
BACKUP_DIR = "./backups"
BACKUP_RETENTION_DAYS = "14"
BOT_INTERNAL_URL = "http://localhost:3000"
